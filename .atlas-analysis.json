  "keyFeatures": [
    "Eloquent-style Models with automatic timestamps and soft deletes",
    "Fluent QueryBuilder with WHERE, JOIN, GROUP BY, HAVING, and aggregations",
    "Complete relationship support (BelongsTo, HasMany, HasOne, ManyToMany)",
    "Laravel-inspired Collections with 50+ transformation methods",
    "Eager loading to prevent N+1 query problems",
    "Automatic type casting (int, bool, json, date)",
    "Reusable query scopes",
    "Accessors and Mutators for data transformation",
    "Model observers for lifecycle hooks",
    "Built-in pagination support"
  ],
  "publicApiSurface": [
    "APPSQL.init(config)",
    "APPSQL.table(sheetName)",
    "Model.create(attributes)",
    "Model.find(id)",
    "Model.all()",
    "Model.where(column, operator, value)",
    "Model.with(...relations)",
    "QueryBuilder.where(column, operator, value)",
    "QueryBuilder.join(table, first, operator, second)",
    "QueryBuilder.orderBy(column, direction)",
    "QueryBuilder.limit(number)",
    "QueryBuilder.get()",
    "QueryBuilder.first()",
    "QueryBuilder.paginate(perPage, page)",
    "Collection.map(callback)",
    "Collection.filter(callback)",
    "Collection.pluck(key)",
    "Collection.groupBy(key)",
    "Collection.sortBy(key)",
    "Collection.sum(key)",
    "Collection.avg(key)",
    "model.save()",
    "model.delete()",
    "model.hasMany(RelatedModel, foreignKey)",
    "model.belongsTo(RelatedModel, foreignKey)",
    "model.hasOne(RelatedModel, foreignKey)",
    "model.manyToMany(RelatedModel, pivotTable)"
  ]
